---
import { Icon } from 'astro-icon/components';

interface Props {
  item: {
    title: string;
    link: string;
    description: string;
    tech: string[];
  };
  variant: 'mobile' | 'desktop-left' | 'desktop-right';
}

const { item, variant } = Astro.props;

const isMobile = variant === 'mobile';
const isLeft = variant === 'desktop-left';

const alignmentClass = isLeft ? "text-right" : "";

const skillContainerClasses = `flex flex-wrap gap-2 ${isLeft ? 'justify-end' : ''}`;
---

<div class={`bg-accent/5 border border-accent/10 p-4 md:p-6 rounded-2xl hover:border-accent/40 transition-all group ${alignmentClass}`}>
  <div class="flex justify-between items-start mb-2">
    <h3 class="text-xl font-heading font-bold text-maintext mt-1">{item.title}</h3>
    <a href={item.link} target="_blank" class="text-accent/75 hover:text-accent transition-colors">
      <Icon name="mdi:open-in-new" class="w-6 h-6" />
    </a>
  </div>

  <p class="text-subtext font-body text-sm leading-relaxed mb-4">{item.description}</p>
  <div class={skillContainerClasses}>
    {item.tech.map((skill: string) => (
      <span class={`rounded-md text-[10px] px-2 md:px-4 py-1 bg-accent/5 border border-accent/10 text-accent/80 group-hover:border-accent/40 group-hover:text-accent`}>{skill}</span>
    ))}
  </div>
</div>
